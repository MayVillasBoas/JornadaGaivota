---
import Base from '../layouts/Base.astro';
import DotNav from '../components/DotNav.astro';
import LensesSection from '../components/LensesSection.astro';
import MentorsSection from '../components/MentorsSection.astro';
import ToolsSection from '../components/ToolsSection.astro';
import MentorModal from '../components/MentorModal.astro';
import '../styles/home.css';
---

<Base title="Referências - may.labs" description="Mentores, lenses, ferramentas e modelos mentais que formam como eu penso.">
  <section class="referencias-header">
    <h1>Referências</h1>
    <p>Mentores, lenses e ferramentas de pensadores que admiro — organizados por domínio de vida. Tudo que me ajuda a pensar com mais clareza sobre o que realmente importa.</p>
  </section>

  <LensesSection />
  <MentorsSection />
  <ToolsSection />

  <DotNav />
  <MentorModal />
</Base>

<style>
  .referencias-header {
    max-width: 680px;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
    text-align: center;
  }

  .referencias-header h1 {
    font-family: 'EB Garamond', serif;
    font-size: 2.8rem;
    font-weight: 400;
    color: var(--ink, #1a1a18);
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .referencias-header p {
    font-family: var(--sans, Inter, sans-serif);
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink-muted, #6b6b68);
    max-width: 540px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .referencias-header {
      padding: 4rem 1.5rem 3rem;
    }

    .referencias-header h1 {
      font-size: 2rem;
    }
  }
</style>
