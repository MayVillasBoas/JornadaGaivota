---
export const prerender = false;

import '../styles/global.css';

// If user already has diario access, redirect to journal
const diarioAccess = Astro.cookies.get('diario-access')?.value;
if (diarioAccess === 'authenticated') {
  return Astro.redirect('/diario');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Journal — May.labs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>

  <div class="login-page">
    <div class="login-card">
      <h1>Journal</h1>
      <p class="subtitle">your life is a movie but you live in a pixel.</p>

      <div class="divider"></div>

      <p class="gate-label">This space is private.</p>
      <div class="field">
        <label for="access-code">Access code</label>
        <input type="password" id="access-code" placeholder="enter the code" autofocus />
      </div>
      <button type="button" id="enter-btn" class="btn-primary">continue</button>
      <div class="error-msg" id="error"></div>
    </div>
  </div>

<script>
  const input = document.getElementById('access-code') as HTMLInputElement;
  const btn = document.getElementById('enter-btn')!;
  const error = document.getElementById('error')!;

  async function tryLogin() {
    const code = input.value.trim();
    if (!code) return;

    btn.textContent = 'verifying...';
    (btn as HTMLButtonElement).disabled = true;
    error.textContent = '';

    const res = await fetch('/api/diario-auth', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code }),
    });

    if (res.ok) {
      window.location.href = '/diario';
    } else {
      const data = await res.json();
      error.textContent = data.error || 'Incorrect code';
      btn.textContent = 'continue';
      (btn as HTMLButtonElement).disabled = false;
      input.value = '';
      input.focus();
    }
  }

  btn.addEventListener('click', tryLogin);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') tryLogin();
  });
</script>

<style>
  body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .login-page {
    width: 100%;
    max-width: 400px;
    padding: 2rem;
  }

  .login-card {
    text-align: center;
  }

  .login-card h1 {
    font-family: var(--serif);
    font-size: 2.8rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--ink-muted);
    margin-bottom: 2.5rem;
  }

  .divider {
    width: 40px;
    height: 1px;
    background: var(--border-light);
    margin: 0 auto 2.5rem;
  }

  .gate-label {
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--ink-muted);
    margin-bottom: 1.5rem;
  }

  .field {
    margin-bottom: 1.2rem;
    text-align: left;
  }

  .field label {
    display: block;
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--ink-muted);
    margin-bottom: 0.4rem;
    letter-spacing: 0.03em;
  }

  .field input {
    width: 100%;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 300;
    padding: 0.8rem 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: white;
    color: var(--ink);
    transition: border-color 0.3s;
  }

  .field input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .field input::placeholder {
    color: var(--ink-muted);
    opacity: 0.5;
  }

  .btn-primary {
    width: 100%;
    margin-top: 0.5rem;
  }

  .error-msg {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: #b44;
    margin-top: 1rem;
    min-height: 1.2rem;
  }
</style>

</html>
