---
import Base from '../layouts/Base.astro';
import CreamCosmos from '../components/CreamCosmos.astro';
import DotNav from '../components/DotNav.astro';
import LensesSection from '../components/LensesSection.astro';
import MentorsSection from '../components/MentorsSection.astro';
import ToolsSection from '../components/ToolsSection.astro';
import MentorModal from '../components/MentorModal.astro';
import '../styles/home.css';
---

<Base title="Unfold — Explore the mind you live in" description="Mental models, mentors, and tools for thinking with more clarity.">
  <CreamCosmos />
  <LensesSection />
  <MentorsSection />
  <ToolsSection />

  <section class="section" id="escrita">
    <h2 class="section-title">Writing</h2>
    <p class="escrita-subtitle">The Seagull's Journey</p>
    <ul class="writing-list">
      <li>
        <a href="/escrita/vergonha-da-primeira-versao">a vergonha da primeira versão</a>
        <span class="date">nov 2024</span>
      </li>
      <li>
        <a href="/escrita/ubuntu">ubuntu</a>
        <span class="date">nov 2024</span>
      </li>
      <li>
        <a href="/escrita/a-gaivota">a gaivota</a>
        <span class="date">jun 2023</span>
      </li>
      <li>
        <a href="/escrita/o-que-fazer-com-a-minha-vida">o que fazer com a minha vida?</a>
        <span class="date">jun 2023</span>
      </li>
    </ul>
  </section>

  <DotNav />
  <MentorModal />
</Base>

<style>
  .escrita-subtitle {
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink-muted);
    text-align: center;
    margin-top: -28px;
    margin-bottom: 2rem;
  }

  .writing-list {
    max-width: 680px;
    margin: 0 auto;
  }

  .writing-list li {
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .writing-list li:first-child {
    border-top: 1px solid var(--border);
  }

  .writing-list a {
    font-family: var(--serif);
    font-size: 1.15rem;
    transition: color 0.3s;
  }

  .writing-list a:hover {
    color: var(--accent);
  }

  .date {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--ink-muted);
  }

  @media (max-width: 768px) {
    .writing-list li {
      flex-direction: column;
      gap: 0.3rem;
    }
  }
</style>
