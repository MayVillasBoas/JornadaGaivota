---
import Base from '../layouts/Base.astro';
import CreamCosmos from '../components/CreamCosmos.astro';
import TwoDoorsSection from '../components/home/TwoDoorsSection.astro';
import LabsSection from '../components/home/LabsSection.astro';
import QuoteSection from '../components/home/QuoteSection.astro';
---

<Base title="may.labs" description="Exploring how AI changes the way we make decisions - at work and in life.">
  <CreamCosmos
    title="may.labs"
    tagline="explorations of a curious mind."
    showInput={false}
    showMentorLabels={false}
  />

  <section class="about-section">
    <div class="about-content narrow">
      <p class="lead">
        I'm May. I build things to understand things.
      </p>

      <p>
        I'm currently exploring how AI changes the way we make decisions -
        at work and in life.
      </p>
    </div>
  </section>

  <TwoDoorsSection />

  <QuoteSection />

  <LabsSection />

</Base>

<style>
  /* About section */
  .about-section {
    padding: 3rem 2rem 2rem;
  }

  .about-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-content p {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-light);
    margin-bottom: 1.5rem;
  }

  .about-content p.lead {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .about-section {
      padding: 3rem 1.5rem 2rem;
    }
  }
</style>
