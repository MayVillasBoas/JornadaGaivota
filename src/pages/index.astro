---
import Base from '../layouts/Base.astro';
import CreamCosmos from '../components/CreamCosmos.astro';
import LabsSection from '../components/home/LabsSection.astro';
import QuoteSection from '../components/home/QuoteSection.astro';
import FrameworksSection from '../components/home/FrameworksSection.astro';
import LinksSection from '../components/home/LinksSection.astro';
---

<Base title="may.labs" description="Um espaço pra explorar ideias, ferramentas e o que me faz pensar.">
  <CreamCosmos
    title="may.labs"
    tagline="explorations of a curious mind."
    showInput={false}
    showMentorLabels={false}
  />

  <section class="about-section">
    <div class="about-content narrow">
      <p class="lead">
        I'm May. I write about what I'm figuring out.
      </p>

      <p>
        Welcome to my little corner of the internet - part library, part lab,
        part journal. A place where I organize the frameworks, mental models,
        and questions that help me (and maybe you) think with more clarity
        about what actually matters.
      </p>

      <p>
        Everything here comes from real life - career changes, grief, starting
        over, figuring out what kind of life I actually want. AI has been helping
        me plot my brain and map how I think. Not theory. Practice.
      </p>
    </div>
  </section>

  <LabsSection />

  <QuoteSection />

  <div class="divider"></div>

  <FrameworksSection />

  <div class="divider"></div>

  <LinksSection />

</Base>

<style>
  /* About section */
  .about-section {
    padding: 5rem 2rem 3rem;
  }

  .about-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-content p {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-light);
    margin-bottom: 1.5rem;
  }

  .about-content p.lead {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.6;
    color: var(--ink);
    margin-bottom: 2rem;
  }

  /* Divider */
  .divider {
    width: 40px;
    height: 1px;
    background: var(--border);
    margin: 1rem auto;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .about-section {
      padding: 3rem 1.5rem 2rem;
    }
  }
</style>
