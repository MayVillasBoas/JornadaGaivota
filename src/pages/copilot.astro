---
import Base from '../layouts/Base.astro';
import '../styles/copilot.css';
---

<Base title="Copiloto de Decisão - May">
  <div class="copilot-container">
    <div class="copilot-welcome" id="copilot-welcome">
      <div class="copilot-hero">
        <div class="copilot-hero-rotate">
          <span class="copilot-hero-fixed">Pense melhor sobre</span>
          <div class="copilot-hero-mask">
            <div class="copilot-hero-track">
              <span>uma mudança de carreira.</span>
              <span>um relacionamento difícil.</span>
              <span>o que você realmente quer.</span>
              <span>uma decisão que te trava.</span>
              <span>o próximo passo.</span>
              <span>um recomeço.</span>
              <span>uma mudança de carreira.</span>
            </div>
          </div>
        </div>
        <p class="copilot-hero-sub">
          A vida é uma sucessão infinita de decisões.<br>
          IA não resolve isso por você — mas, sabendo usá-la bem,<br class="hide-mobile">
          você chega mais perto da clareza.
        </p>
      </div>

      <div class="copilot-how">
        <p class="copilot-how-title">Como funciona</p>
        <div class="copilot-steps">
          <div class="copilot-step">
            <div class="copilot-step-num">1</div>
            <div class="copilot-step-content">
              <h3>Conte</h3>
              <p>Descreva o que te trava. Pode ser bagunçado — é só pra você.</p>
            </div>
          </div>
          <div class="copilot-step-connector"></div>
          <div class="copilot-step">
            <div class="copilot-step-num">2</div>
            <div class="copilot-step-content">
              <h3>Explore</h3>
              <p>Frameworks de decisão escolhidos pra sua situação te guiam por ângulos que você não viu.</p>
            </div>
          </div>
          <div class="copilot-step-connector"></div>
          <div class="copilot-step">
            <div class="copilot-step-num">3</div>
            <div class="copilot-step-content">
              <h3>Decida</h3>
              <p>Um memo com o que você descobriu, seus trade-offs reais e o próximo passo concreto.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="copilot-timeline" id="copilot-timeline">
      <!-- Engine renders conversation blocks here -->
    </div>
    <div class="copilot-input copilot-input--welcome" id="copilot-input">
      <h2 class="copilot-input-title" id="copilot-input-title">Comece aqui</h2>
      <div class="copilot-input-inner">
        <div class="voice-group">
          <button class="voice-lang-toggle" id="voice-lang" data-lang="pt-BR" aria-label="Idioma do reconhecimento de voz" title="Idioma do reconhecimento de voz">pt</button>
          <button class="copilot-voice-btn" id="copilot-mic" aria-label="Start voice recording" aria-pressed="false">
            <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
          </button>
        </div>
        <textarea id="copilot-text" placeholder="Descreva a decisão que te trava..." rows="2"></textarea>
        <button class="copilot-send-btn" id="copilot-send" disabled>
          <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
      <p class="copilot-empty-hint" id="copilot-hint">sem pressa — até poucas palavras ajudam</p>
      <p class="copilot-input-hint" id="copilot-keyboard-hint">Enter para nova linha · clique enviar ou ⌘+Enter para enviar</p>
    </div>
  </div>
</Base>

<script>
  import { CopilotEngine } from '../scripts/copilot/engine';

  if (!(window as any).__copilotInit) {
    (window as any).__copilotInit = true;

    const timeline = document.getElementById('copilot-timeline');
    const canvas = null as any;
    const mic = document.getElementById('copilot-mic') as HTMLButtonElement;
    const textarea = document.getElementById('copilot-text') as HTMLTextAreaElement;
    const sendBtn = document.getElementById('copilot-send') as HTMLButtonElement;
    const hint = document.getElementById('copilot-hint') as HTMLElement;

    if (timeline) {
      const engine = new CopilotEngine({
        timeline,
        canvas,
        mic,
        textarea,
        sendBtn,
        hint,
      });
      engine.init();
    }
  }
</script>
