---
import Base from '../layouts/Base.astro';
import '../styles/journal.css';
---

<Base title="May.OS" description="Your personal operating system.">

  <section class="journal-hero">
    <h1>May.OS</h1>
    <p class="journal-subtitle">your personal operating system</p>
  </section>

  <div class="journal-tabs">
    <button class="journal-tab active" data-view="checkin">check-in</button>
    <button class="journal-tab" data-view="saude">health</button>
    <button class="journal-tab" data-view="calendario">calendar</button>
    <button class="journal-tab" data-view="timeline">timeline</button>
    <button class="journal-tab" data-view="vault">vault</button>
  </div>

  <!-- ─── Check-in View ─── -->
  <section class="journal-view active" id="view-checkin">
    <div class="checkin-container">

      <!-- Textarea + Voice -->
      <div class="checkin-input-area">
        <label for="journal-text" class="checkin-label">how's your energy today?</label>
        <div class="textarea-wrapper">
          <textarea
            id="journal-text"
            placeholder="write or speak freely..."
            rows="6"
          ></textarea>
          <button class="voice-btn" data-target="journal-text" aria-label="Start voice recording">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Energy Trackers -->
      <div class="trackers-area" id="trackers-area">
        <div class="trackers-header">
          <span class="trackers-label">tracking today</span>
          <button class="add-tracker-btn" id="add-tracker-btn" title="add tracker">+</button>
        </div>
        <div class="tracker-chips" id="tracker-chips">
          <!-- Populated by JS -->
        </div>
        <!-- Add tracker form (hidden by default) -->
        <div class="add-tracker-form" id="add-tracker-form" style="display:none">
          <input type="text" id="new-tracker-label" placeholder="name (e.g. Walking)" maxlength="30" />
          <input type="text" id="new-tracker-emoji" placeholder="emoji" maxlength="4" style="width:60px" />
          <select id="new-tracker-category">
            <option value="body">body</option>
            <option value="mind">mind</option>
            <option value="relationships">relationships</option>
            <option value="soul">soul</option>
          </select>
          <button class="btn-save-tracker" id="btn-save-tracker">save</button>
        </div>
      </div>

      <!-- Save Button -->
      <button class="btn-checkin" id="btn-checkin">save check-in</button>

      <!-- Loading -->
      <div class="checkin-loading" id="checkin-loading" style="display:none">
        <div class="loading-dots"><span>.</span><span>.</span><span>.</span></div>
        <span class="loading-label">analyzing your energy...</span>
      </div>

      <!-- AI Reflection (appears after save) -->
      <div class="ai-reflection" id="ai-reflection" style="display:none">
        <div class="reflection-card">
          <span class="reflection-marker">✦ reflection</span>
          <p class="reflection-text" id="reflection-text"></p>
        </div>

        <!-- Celebrations -->
        <div class="celebrations" id="celebrations" style="display:none">
          <span class="celebration-marker">✨ celebrating</span>
          <ul class="celebration-list" id="celebration-list"></ul>
        </div>

        <!-- Energy + Tone summary -->
        <div class="energy-summary" id="energy-summary" style="display:none">
          <div class="energy-badge" id="energy-badge"></div>
          <div class="tone-badge" id="tone-badge"></div>
          <div class="themes-pills" id="themes-pills"></div>
        </div>

        <!-- Tracker Suggestion -->
        <div class="tracker-suggestion" id="tracker-suggestion" style="display:none">
          <span class="suggestion-marker">💬 suggestion</span>
          <p class="suggestion-text" id="suggestion-text"></p>
          <div class="suggestion-actions">
            <button class="btn-accept-suggestion" id="btn-accept-suggestion">yes, I want to track this</button>
            <button class="btn-dismiss-suggestion" id="btn-dismiss-suggestion">not now</button>
          </div>
        </div>
      </div>

      <!-- Today's existing entry (if any) -->
      <div class="existing-entry" id="existing-entry" style="display:none">
        <span class="existing-label">today's entry</span>
        <p class="existing-text" id="existing-text"></p>
        <div class="existing-meta" id="existing-meta"></div>
      </div>

    </div>
  </section>

  <!-- ─── Health View ─── -->
  <section class="journal-view" id="view-saude">
    <div class="health-container">
      <!-- Daily Macros Summary -->
      <div class="health-macros-card" id="health-macros-card">
        <span class="health-section-label">today's nutrition</span>
        <div class="macro-bars" id="macro-bars">
          <!-- Populated by JS -->
        </div>
      </div>

      <!-- Meals List -->
      <div class="health-section">
        <span class="health-section-label">meals</span>
        <div class="health-meals" id="health-meals"></div>
      </div>

      <!-- Workouts -->
      <div class="health-section">
        <span class="health-section-label">workouts</span>
        <div class="health-workouts" id="health-workouts"></div>
      </div>

      <div class="health-empty" id="health-empty" style="display:none">
        <p class="timeline-empty-text">no health data yet today</p>
      </div>
    </div>
  </section>

  <!-- ─── Calendar View ─── -->
  <section class="journal-view wide" id="view-calendario">
    <div class="calendar-container">
      <div class="calendar-nav">
        <button class="cal-nav-btn" id="cal-prev">&larr;</button>
        <h2 class="cal-month-label" id="cal-month-label"></h2>
        <button class="cal-nav-btn" id="cal-next">&rarr;</button>
      </div>

      <div class="calendar-grid" id="calendar-grid">
        <div class="cal-header">mon</div>
        <div class="cal-header">tue</div>
        <div class="cal-header">wed</div>
        <div class="cal-header">thu</div>
        <div class="cal-header">fri</div>
        <div class="cal-header">sat</div>
        <div class="cal-header">sun</div>
        <!-- Day cells populated by JS -->
      </div>

      <div class="calendar-legend" id="calendar-legend">
        <span class="legend-item"><span class="legend-dot" style="background:#4a7aad"></span> serenity</span>
        <span class="legend-item"><span class="legend-dot" style="background:#4aad6a"></span> gratitude</span>
        <span class="legend-item"><span class="legend-dot" style="background:#c27a5a"></span> fire</span>
        <span class="legend-item"><span class="legend-dot" style="background:#ada45a"></span> joy</span>
        <span class="legend-item"><span class="legend-dot" style="background:#2B4A3E"></span> heaviness</span>
        <span class="legend-item"><span class="legend-dot" style="background:#8b6aad"></span> fog</span>
        <span class="legend-item"><span class="legend-dot" style="background:#4a7aad"></span> presence</span>
        <span class="legend-item"><span class="legend-dot" style="background:#ada45a"></span> travessia</span>
      </div>

      <!-- Day detail (appears on click) -->
      <div class="day-detail" id="day-detail" style="display:none">
        <div class="day-detail-header">
          <span class="day-detail-date" id="day-detail-date"></span>
          <button class="day-detail-close" id="day-detail-close">&times;</button>
        </div>
        <div class="day-detail-energy" id="day-detail-energy"></div>
        <p class="day-detail-text" id="day-detail-text"></p>
        <div class="day-detail-trackers" id="day-detail-trackers"></div>
      </div>
    </div>
  </section>

  <!-- ─── Timeline View ─── -->
  <section class="journal-view" id="view-timeline">
    <div class="timeline-container">
      <div class="timeline-empty" id="timeline-empty" style="display:none">
        <p class="timeline-empty-text">nothing here yet — send something via WhatsApp</p>
      </div>
      <div class="timeline-entries" id="timeline-entries"></div>
      <button class="btn-load-more" id="btn-load-more" style="display:none">load more</button>
      <div class="timeline-loading" id="timeline-loading" style="display:none">
        <div class="loading-dots"><span>.</span><span>.</span><span>.</span></div>
      </div>
    </div>
  </section>

  <!-- ─── Vault View ─── -->
  <section class="journal-view" id="view-vault">
    <div class="vault-container">
      <div class="vault-filters">
        <div class="vault-search-wrapper">
          <input type="text" id="vault-search" class="vault-search" placeholder="search..." />
        </div>
        <div class="vault-tags" id="vault-tags"></div>
      </div>
      <div class="vault-empty" id="vault-empty" style="display:none">
        <p class="timeline-empty-text">no vault entries yet</p>
      </div>
      <div class="vault-entries" id="vault-entries"></div>
    </div>
  </section>

</Base>

<script>
  import '../scripts/voice-input';
  import '../scripts/journal-ui';
  import '../scripts/hub-ui';
</script>
