---
import Base from '../../layouts/Base.astro';
import '../../styles/guided-tool.css';
---

<Base title="Energy Audit — May">

  <section class="tool-hero">
    <span class="tool-label">tool 05</span>
    <h1>Energy Audit</h1>
    <p class="tool-intro">
      Map what drains you and what restores you. Because reorganizing your life starts by
      honestly seeing where you're spending your energy — and where it's coming back.
    </p>
    <p class="tool-origin">May curation</p>
  </section>

  <div class="divider"></div>

  <section class="guided-experience" id="experience">

    <!-- Resume prompt -->
    <div class="resume-prompt">
      <p></p>
      <div class="resume-actions">
        <button class="btn-primary btn-resume">continue</button>
        <button class="btn-secondary btn-restart">start over</button>
      </div>
    </div>

    <!-- Unified fractal visualization -->
    <div class="fractal-viz" id="fractal-viz"></div>

    <!-- Transition screen -->
    <div class="transition-screen">
      <div class="transition-dots"><span>.</span><span>.</span><span>.</span></div>
    </div>

    <!-- Completion breath -->
    <div class="completion-breath">
      <div class="breath-text"></div>
    </div>

    <!-- Step 0: Intro -->
    <div class="step active" data-step="0">
      <div class="step-content">
        <p class="step-context">
          We intuitively know what drains us and what energizes us. But we rarely stop to
          map it honestly. When you truly look, patterns emerge —
          and it becomes easier to make decisions that protect your energy.
        </p>
        <p class="step-context">
          Here you'll take a real inventory of your week. No judgment, no forced optimism.
        </p>
        <button class="btn-primary step-next">begin <span class="arrow">→</span></button>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" data-step="1">
      <div class="step-header">
        <span class="step-number">1 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What drains you?</h2>
        <p class="step-guide">
          Think about your typical week. What activities, people, commitments, or habits leave you
          more tired than before? List everything — work, relationships, routine, social obligations.
        </p>
        <textarea id="q1" placeholder="What drains my energy is..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step" data-step="2">
      <div class="step-header">
        <span class="step-number">2 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What restores you?</h2>
        <p class="step-guide">
          Now the other side. What makes you feel more alive, present, energized?
          It could be an activity, a person, a place, a time of day.
          Include the small things too.
        </p>
        <textarea id="q2" placeholder="What restores my energy is..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step" data-step="3">
      <div class="step-header">
        <span class="step-number">3 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Is the balance positive or negative?</h2>
        <p class="step-guide">
          Look at both lists. If your week were an energy bank account,
          would you be in the black or in the red? What dominates? For how long?
        </p>
        <textarea id="q3" placeholder="My energy balance is..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="step" data-step="4">
      <div class="step-header">
        <span class="step-number">4 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What can you eliminate or reduce?</h2>
        <p class="step-guide">
          In the list of what drains you, what's within your control to change?
          It doesn't have to be everything at once. What's the most draining item you
          could eliminate, delegate, reduce, or transform?
        </p>
        <textarea id="q4" placeholder="I could eliminate or reduce..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="step" data-step="5">
      <div class="step-header">
        <span class="step-number">5 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What can you amplify?</h2>
        <p class="step-guide">
          In the list of what restores you, what could get more space in your week?
          How could you protect that time or create more of it?
        </p>
        <textarea id="q5" placeholder="I could amplify or protect..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 6 -->
    <div class="step" data-step="6">
      <div class="step-header">
        <span class="step-number">6 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>One change for this week</h2>
        <p class="step-guide">
          You don't need to redesign your entire life right now.
          Choose one thing to change this week — one thing to remove or one to add.
          Small enough to be real. Concrete enough to happen.
        </p>
        <textarea id="q6" placeholder="This week, I will..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary" id="finish-btn">see my audit <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="step" data-step="result">
      <div class="step-content result-content">
        <h2>Your energy audit</h2>
        <p class="result-intro">An honest map of where your energy is going — and where it can come back from.</p>

        <div class="result-block"><h3>What drains me</h3><p id="r1"></p></div>
        <div class="result-block"><h3>What restores me</h3><p id="r2"></p></div>
        <div class="result-block"><h3>My balance</h3><p id="r3"></p></div>
        <div class="result-block"><h3>What I can eliminate or reduce</h3><p id="r4"></p></div>
        <div class="result-block"><h3>What I can amplify</h3><p id="r5"></p></div>
        <div class="result-block closing-block"><h3>My change for this week</h3><p id="r6"></p></div>

        <div class="reflection-prompt">
          <span class="reflection-label">a question to take with you</span>
          <p class="reflection-text">If energy is currency, what are you spending yours on — and what do you want to invest in?</p>
        </div>

        <div class="reflection-counter"></div>

        <div class="result-actions">
          <button class="btn-secondary" id="copy-btn">copy text</button>
          <button class="btn-secondary" id="download-btn">save as text</button>
          <button class="btn-secondary" id="save-journal-btn">save to journal</button>
          <button class="btn-secondary" id="restart-btn">redo ↺</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { GuidedTool } from '../../scripts/guided-tool';
  import { initToolVisuals } from '../../scripts/tool-visuals';

  if (!(window as any).__guidedToolInit) {
    (window as any).__guidedToolInit = true;

  const config = {
    slug: 'auditoria-de-energia',
    totalSteps: 6,
    fields: [
      { input: 'q1', output: 'r1' },
      { input: 'q2', output: 'r2' },
      { input: 'q3', output: 'r3' },
      { input: 'q4', output: 'r4' },
      { input: 'q5', output: 'r5' },
      { input: 'q6', output: 'r6' },
    ],
    encouragements: [
      '',
      'Seeing what drains you is already an act of self-protection.',
      'Now the other side. Good energy exists — sometimes it just needs space.',
      'Seeing the balance honestly is the first step to change.',
      'Eliminating one drain already frees space for something better.',
      'Amplifying what restores you is as important as cutting what drains.',
      'A small, real change is worth more than a big, vague plan.',
    ],
    closingReflection: 'If energy is currency, what are you spending yours on — and what do you want to invest in?',
    resultTitle: 'Energy Audit',
    visualConfig: {
      type: 'energy-balance',
      sections: [
        { id: 'drena', label: 'drains', stepRange: [1], wordClass: 'drains' },
        { id: 'devolve', label: 'restores', stepRange: [2], wordClass: 'restores' },
        { id: 'balanco', label: 'balance', stepRange: [3], wordClass: 'neutral' },
        { id: 'eliminar', label: 'eliminate', stepRange: [4], wordClass: 'strategy' },
        { id: 'ampliar', label: 'amplify', stepRange: [5], wordClass: 'strategy' },
        { id: 'mudanca', label: 'change', stepRange: [6], wordClass: 'genuine' },
      ],
    },
  };

  const tool = new GuidedTool(config);
  tool.init();
  GuidedTool.wireExport(config);
  initToolVisuals(config.slug);

  }
</script>
