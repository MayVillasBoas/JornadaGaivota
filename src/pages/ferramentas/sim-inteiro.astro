---
import Base from '../../layouts/Base.astro';
import '../../styles/guided-tool.css';
---

<Base title="Sim de corpo inteiro — May">

  <section class="tool-hero">
    <span class="tool-label">ferramenta 03</span>
    <h1>Sim de corpo inteiro</h1>
    <p class="tool-intro">
      Se não é um "sim!" claro, é um não. Esta ferramenta te ajuda a separar o que é desejo
      genuíno do que é obrigação, culpa ou medo de desagradar.
    </p>
    <p class="tool-origin">Baseado em Hell Yes or No — Derek Sivers</p>
  </section>

  <div class="divider"></div>

  <section class="guided-experience" id="experience">

    <!-- Resume prompt -->
    <div class="resume-prompt">
      <p></p>
      <div class="resume-actions">
        <button class="btn-primary btn-resume">continuar</button>
        <button class="btn-secondary btn-restart">começar de novo</button>
      </div>
    </div>

    <!-- Visual artifact: Radiografia da decisão -->
    <div class="tool-visual" id="tool-visual">
      <div class="tool-visual-header">sua radiografia</div>
    </div>

    <!-- Transition screen -->
    <div class="transition-screen">
      <div class="transition-dots"><span>.</span><span>.</span><span>.</span></div>
    </div>

    <!-- Completion breath -->
    <div class="completion-breath">
      <div class="breath-text"></div>
    </div>

    <!-- Step 0: Intro -->
    <div class="step active" data-step="0">
      <div class="step-content">
        <p class="step-context">
          A ideia do Derek Sivers é simples e radical: quando você diz sim para tudo,
          não sobra espaço para o que realmente importa. O filtro é brutal —
          ou é um "sim!" de corpo inteiro, ou é um não.
        </p>
        <p class="step-context">
          Aqui você vai examinar uma decisão que está tomando agora e testar
          se o seu sim é verdadeiro ou automático.
        </p>
        <button class="btn-primary step-next">começar <span class="arrow">→</span></button>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" data-step="1">
      <div class="step-header">
        <span class="step-number">1 de 5</span>
        <div class="step-progress"><div class="progress-fill" style="width: 0%"></div></div>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflexão</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>O que está em jogo?</h2>
        <p class="step-guide">
          Descreva a decisão, convite ou compromisso que você está considerando.
          Pode ser um projeto, uma relação, uma mudança, um pedido. O que está na sua mesa agora?
        </p>
        <textarea id="q1" placeholder="Estou considerando..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> voltar</button>
          <button class="btn-primary step-next">próximo <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step" data-step="2">
      <div class="step-header">
        <span class="step-number">2 de 5</span>
        <div class="step-progress"><div class="progress-fill" style="width: 0%"></div></div>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflexão</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Por que você está dizendo sim?</h2>
        <p class="step-guide">
          Seja honesta. É porque quer de verdade? Porque tem medo de perder a oportunidade?
          Porque não quer desapontar alguém? Porque "deveria"? Liste todos os motivos — os bonitos e os feios.
        </p>
        <textarea id="q2" placeholder="Estou dizendo sim porque..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> voltar</button>
          <button class="btn-primary step-next">próximo <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step" data-step="3">
      <div class="step-header">
        <span class="step-number">3 de 5</span>
        <div class="step-progress"><div class="progress-fill" style="width: 0%"></div></div>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflexão</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>O teste do corpo</h2>
        <p class="step-guide">
          Feche os olhos por um momento. Imagine que você já disse sim e está vivendo isso.
          Como o seu corpo reage? Expansão, leveza, energia? Ou contração, peso, aperto no peito?
          Descreva a sensação — sem julgar.
        </p>
        <textarea id="q3" placeholder="Quando imagino vivendo isso, meu corpo..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> voltar</button>
          <button class="btn-primary step-next">próximo <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="step" data-step="4">
      <div class="step-header">
        <span class="step-number">4 de 5</span>
        <div class="step-progress"><div class="progress-fill" style="width: 0%"></div></div>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflexão</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Se eu dissesse não — o que aconteceria?</h2>
        <p class="step-guide">
          Imagine que você recusa. O que muda? Quem fica desapontado? O que sobra de espaço?
          Você sente alívio ou arrependimento? Essa resposta diz muito.
        </p>
        <textarea id="q4" placeholder="Se eu dissesse não..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> voltar</button>
          <button class="btn-primary step-next">próximo <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="step" data-step="5">
      <div class="step-header">
        <span class="step-number">5 de 5</span>
        <div class="step-progress"><div class="progress-fill" style="width: 0%"></div></div>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflexão</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Seu veredicto</h2>
        <p class="step-guide">
          Olhando tudo que você escreveu — é um sim de corpo inteiro?
          Ou é um sim de cabeça, de culpa, de medo? Escreva sua conclusão honesta.
          Não precisa ser definitiva. Precisa ser sua.
        </p>
        <textarea id="q5" placeholder="Minha conclusão honesta é que..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> voltar</button>
          <button class="btn-primary" id="finish-btn">ver meu veredicto <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="step" data-step="result">
      <div class="step-content result-content">
        <h2>Seu veredicto</h2>
        <p class="result-intro">O que apareceu quando você parou pra escutar.</p>

        <div class="result-block"><h3>A decisão</h3><p id="r1"></p></div>
        <div class="result-block"><h3>Por que estou dizendo sim</h3><p id="r2"></p></div>
        <div class="result-block"><h3>O que o corpo diz</h3><p id="r3"></p></div>
        <div class="result-block"><h3>Se eu dissesse não</h3><p id="r4"></p></div>
        <div class="result-block closing-block"><h3>Minha conclusão</h3><p id="r5"></p></div>

        <div class="reflection-prompt">
          <span class="reflection-label">uma pergunta para levar</span>
          <p class="reflection-text">O que muda na sua vida se você começa a dizer não para os sins automáticos?</p>
        </div>

        <div class="reflection-counter"></div>

        <div class="result-actions">
          <button class="btn-secondary" id="copy-btn">copiar texto</button>
          <button class="btn-secondary" id="download-btn">salvar como texto</button>
          <button class="btn-secondary" id="save-journal-btn">guardar no diário</button>
          <button class="btn-secondary" id="restart-btn">refazer ↺</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { GuidedTool } from '../../scripts/guided-tool';

  // Prevent duplicate instantiation
  if (!(window as any).__guidedToolInit) {
    (window as any).__guidedToolInit = true;

  const config = {
    slug: 'sim-inteiro',
    totalSteps: 5,
    fields: [
      { input: 'q1', output: 'r1' },
      { input: 'q2', output: 'r2' },
      { input: 'q3', output: 'r3' },
      { input: 'q4', output: 'r4' },
      { input: 'q5', output: 'r5' },
    ],
    encouragements: [
      '', // step 0
      'Boa. Colocar na mesa já é um ato de honestidade.',
      'Separar os motivos é corajoso.',
      'O corpo sabe antes da cabeça. Confie nele.',
      'Imaginar o não é tão revelador quanto imaginar o sim.',
      'Agora é só você e sua resposta honesta.',
    ],
    closingReflection: 'O que muda na sua vida se você começa a dizer não para os sins automáticos?',
    resultTitle: 'Sim de corpo inteiro',
    visualConfig: {
      type: 'decision-xray',
      sections: [
        { id: 'decision', label: 'a decisão', stepRange: [1], wordClass: 'neutral' },
        { id: 'motives', label: 'motivos', stepRange: [2], wordClass: 'obligation' },
        { id: 'body', label: 'o corpo diz', stepRange: [3], wordClass: 'genuine' },
        { id: 'alternative', label: 'se eu dissesse não', stepRange: [4], wordClass: 'neutral' },
        { id: 'verdict', label: 'veredicto', stepRange: [5], wordClass: 'genuine' },
      ],
    },
  };

  const tool = new GuidedTool(config);
  tool.init();
  GuidedTool.wireExport(config);

  } // end guard
</script>
