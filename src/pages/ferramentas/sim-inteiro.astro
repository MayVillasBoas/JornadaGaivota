---
import Base from '../../layouts/Base.astro';
import '../../styles/guided-tool.css';
---

<Base title="Hell Yes or No — May">

  <section class="tool-hero">
    <span class="tool-label">tool 03</span>
    <h1>Hell Yes or No</h1>
    <p class="tool-intro">
      If it's not a clear "yes!", it's a no. This tool helps you separate genuine desire
      from obligation, guilt, or fear of disappointing others.
    </p>
    <p class="tool-origin">Based on Hell Yes or No — Derek Sivers</p>
  </section>

  <div class="divider"></div>

  <section class="guided-experience" id="experience">

    <!-- Resume prompt -->
    <div class="resume-prompt">
      <p></p>
      <div class="resume-actions">
        <button class="btn-primary btn-resume">continue</button>
        <button class="btn-secondary btn-restart">start over</button>
      </div>
    </div>

    <!-- Unified fractal visualization -->
    <div class="fractal-viz" id="fractal-viz"></div>

    <!-- Transition screen -->
    <div class="transition-screen">
      <div class="transition-dots"><span>.</span><span>.</span><span>.</span></div>
    </div>

    <!-- Completion breath -->
    <div class="completion-breath">
      <div class="breath-text"></div>
    </div>

    <!-- Step 0: Intro -->
    <div class="step active" data-step="0">
      <div class="step-content">
        <p class="step-context">
          Derek Sivers' idea is simple and radical: when you say yes to everything,
          there's no room left for what truly matters. The filter is brutal —
          it's either a full-body "yes!", or it's a no.
        </p>
        <p class="step-context">
          Here you'll examine a decision you're facing right now and test
          whether your yes is genuine or automatic.
        </p>
        <button class="btn-primary step-next">begin <span class="arrow">→</span></button>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" data-step="1">
      <div class="step-header">
        <span class="step-number">1 de 5</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What's at stake?</h2>
        <p class="step-guide">
          Describe the decision, invitation, or commitment you're considering.
          It could be a project, a relationship, a change, a request. What's on your plate right now?
        </p>
        <textarea id="q1" placeholder="I'm considering..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step" data-step="2">
      <div class="step-header">
        <span class="step-number">2 de 5</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Why are you saying yes?</h2>
        <p class="step-guide">
          Be honest. Is it because you truly want to? Because you're afraid of missing out?
          Because you don't want to disappoint someone? Because you "should"? List all the reasons — the pretty and the ugly.
        </p>
        <textarea id="q2" placeholder="I'm saying yes because..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step" data-step="3">
      <div class="step-header">
        <span class="step-number">3 de 5</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>The body test</h2>
        <p class="step-guide">
          Close your eyes for a moment. Imagine you've already said yes and you're living it.
          How does your body react? Expansion, lightness, energy? Or contraction, heaviness, tightness in the chest?
          Describe the sensation — without judging.
        </p>
        <textarea id="q3" placeholder="When I imagine living this, my body..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="step" data-step="4">
      <div class="step-header">
        <span class="step-number">4 de 5</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>If I said no — what would happen?</h2>
        <p class="step-guide">
          Imagine you decline. What changes? Who gets disappointed? What space opens up?
          Do you feel relief or regret? That answer says a lot.
        </p>
        <textarea id="q4" placeholder="If I said no..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="step" data-step="5">
      <div class="step-header">
        <span class="step-number">5 de 5</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Your verdict</h2>
        <p class="step-guide">
          Looking at everything you wrote — is it a full-body yes?
          Or is it a head-yes, a guilt-yes, a fear-yes? Write your honest conclusion.
          It doesn't need to be final. It needs to be yours.
        </p>
        <textarea id="q5" placeholder="My honest conclusion is that..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary" id="finish-btn">see my verdict <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="step" data-step="result">
      <div class="step-content result-content">
        <h2>Your verdict</h2>
        <p class="result-intro">What surfaced when you stopped to listen.</p>

        <div class="result-block"><h3>The decision</h3><p id="r1"></p></div>
        <div class="result-block"><h3>Why I'm saying yes</h3><p id="r2"></p></div>
        <div class="result-block"><h3>What the body says</h3><p id="r3"></p></div>
        <div class="result-block"><h3>If I said no</h3><p id="r4"></p></div>
        <div class="result-block closing-block"><h3>My conclusion</h3><p id="r5"></p></div>

        <div class="reflection-prompt">
          <span class="reflection-label">a question to take with you</span>
          <p class="reflection-text">What changes in your life if you start saying no to your automatic yeses?</p>
        </div>

        <div class="reflection-counter"></div>

        <div class="result-actions">
          <button class="btn-secondary" id="copy-btn">copy text</button>
          <button class="btn-secondary" id="download-btn">save as text</button>
          <button class="btn-secondary" id="save-journal-btn">save to journal</button>
          <button class="btn-secondary" id="restart-btn">redo ↺</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { GuidedTool } from '../../scripts/guided-tool';
  import { initToolVisuals } from '../../scripts/tool-visuals';

  // Prevent duplicate instantiation
  if (!(window as any).__guidedToolInit) {
    (window as any).__guidedToolInit = true;

  const config = {
    slug: 'sim-inteiro',
    totalSteps: 5,
    fields: [
      { input: 'q1', output: 'r1' },
      { input: 'q2', output: 'r2' },
      { input: 'q3', output: 'r3' },
      { input: 'q4', output: 'r4' },
      { input: 'q5', output: 'r5' },
    ],
    encouragements: [
      '', // step 0
      'Good. Putting it on the table is already an act of honesty.',
      'Separating the motives takes courage.',
      'The body knows before the head. Trust it.',
      'Imagining the no is as revealing as imagining the yes.',
      'Now it\'s just you and your honest answer.',
    ],
    closingReflection: 'What changes in your life if you start saying no to your automatic yeses?',
    resultTitle: 'Hell Yes or No',
    visualConfig: {
      type: 'decision-xray',
      sections: [
        { id: 'decision', label: 'the decision', stepRange: [1], wordClass: 'neutral' },
        { id: 'motives', label: 'motives', stepRange: [2], wordClass: 'obligation' },
        { id: 'body', label: 'body says', stepRange: [3], wordClass: 'genuine' },
        { id: 'alternative', label: 'if I said no', stepRange: [4], wordClass: 'neutral' },
        { id: 'verdict', label: 'verdict', stepRange: [5], wordClass: 'genuine' },
      ],
    },
  };

  const tool = new GuidedTool(config);
  tool.init();
  GuidedTool.wireExport(config);
  initToolVisuals(config.slug);

  } // end guard
</script>
