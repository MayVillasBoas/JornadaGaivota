---
import Base from '../../layouts/Base.astro';
import '../../styles/guided-tool.css';
---

<Base title="3 Plausible Futures - May">

  <section class="tool-hero">
    <span class="tool-label">tool 02</span>
    <h1>3 Plausible Futures</h1>
    <p class="tool-intro">
      You don't need to choose an entire life in your head. This tool helps you imagine
      three honest versions of your next chapter - to feel which one calls for a test, not a final decision.
    </p>
    <p class="tool-origin">Based on Odyssey Plan - Design Your Life</p>
  </section>

  <div class="divider"></div>

  <section class="guided-experience" id="experience">

    <!-- Resume prompt -->
    <div class="resume-prompt">
      <p></p>
      <div class="resume-actions">
        <button class="btn-primary btn-resume">continue</button>
        <button class="btn-secondary btn-restart">start over</button>
      </div>
    </div>

    <!-- Unified fractal visualization -->
    <div class="fractal-viz" id="fractal-viz"></div>

    <!-- Transition screen -->
    <div class="transition-screen">
      <div class="transition-dots"><span>.</span><span>.</span><span>.</span></div>
    </div>

    <!-- Completion breath -->
    <div class="completion-breath">
      <div class="breath-text"></div>
    </div>

    <!-- Step 0: Intro -->
    <div class="step active" data-step="0">
      <div class="step-content">
        <p class="step-context">
          The Odyssey Plan starts from a simple premise: you don't have one possible life.
          You have several. And the best way to choose isn't to analyze - it's to imagine honestly
          and then test.
        </p>
        <p class="step-context">
          Here you'll sketch three versions of your next year. It doesn't need to be perfect.
          It needs to be honest.
        </p>
        <button class="btn-primary step-next">begin <span class="arrow">→</span></button>
      </div>
    </div>

    <!-- Step 1: Vida 1 -->
    <div class="step" data-step="1">
      <div class="step-header">
        <span class="step-number">1 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Life 1 - The current path</h2>
        <p class="step-guide">
          If you continue on the path you're on, what does your life look like a year from now?
          Where do you live, what do you do, who's around you, how do you feel?
          No judgment - just describe.
        </p>
        <textarea id="q1" placeholder="A year from now, if I stay on this path..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 2: Vida 2 -->
    <div class="step" data-step="2">
      <div class="step-header">
        <span class="step-number">2 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Life 2 - The reinvention</h2>
        <p class="step-guide">
          If you changed more radically - career, city, relationship, lifestyle -
          what would it look like? This is the life you fantasize about when you're dissatisfied.
          Let it exist on paper.
        </p>
        <textarea id="q2" placeholder="If I reinvented my life more radically..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 3: Vida 3 -->
    <div class="step" data-step="3">
      <div class="step-header">
        <span class="step-number">3 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Life 3 - No fear of judgment</h2>
        <p class="step-guide">
          If money, status, and others' opinions weren't factors - what would it look like?
          This is the life you might not even allow yourself to imagine. Write without censoring.
        </p>
        <textarea id="q3" placeholder="If nothing external limited me, I would..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 4: O que anima / pesa -->
    <div class="step" data-step="4">
      <div class="step-header">
        <span class="step-number">4 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What excites you and what weighs you down in each?</h2>
        <p class="step-guide">
          Reread your three lives. For each, note what gives you energy and what drains you.
          It doesn't need to be logical - trust the reaction.
        </p>
        <label class="textarea-label">Life 1 - what excites / what weighs</label>
        <textarea id="q4a" placeholder="Excites: ... / Weighs: ..." rows="3"></textarea>
        <label class="textarea-label">Life 2 - what excites / what weighs</label>
        <textarea id="q4b" placeholder="Excites: ... / Weighs: ..." rows="3"></textarea>
        <label class="textarea-label">Life 3 - what excites / what weighs</label>
        <textarea id="q4c" placeholder="Excites: ... / Weighs: ..." rows="3"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="step" data-step="5">
      <div class="step-header">
        <span class="step-number">5 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Which one calls for a test - not a decision?</h2>
        <p class="step-guide">
          You don't need to choose now. You need to test. Which of these lives could you
          try on a small scale? A conversation, a week, a pilot project.
        </p>
        <textarea id="q5" placeholder="The life I most want to test is... because..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 6 -->
    <div class="step" data-step="6">
      <div class="step-header">
        <span class="step-number">6 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What's the smallest possible test?</h2>
        <p class="step-guide">
          You don't need to quit everything. What's the cheapest, fastest, safest prototype
          that would give you a taste of that life? A conversation with someone who already lives it?
          A week trying it? A side project?
        </p>
        <textarea id="q6" placeholder="The smallest test I could do in the next 14 days is..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary" id="finish-btn">see my map <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="step" data-step="result">
      <div class="step-content result-content">
        <h2>Your 3 futures</h2>
        <p class="result-intro">Three honest versions of your next chapter.</p>

        <div class="result-block"><h3>Life 1 - Current path</h3><p id="r1"></p></div>
        <div class="result-block"><h3>Life 2 - Reinvention</h3><p id="r2"></p></div>
        <div class="result-block"><h3>Life 3 - No limits</h3><p id="r3"></p></div>
        <div class="result-block"><h3>What excites and weighs</h3>
          <p id="r4a"></p><p id="r4b"></p><p id="r4c"></p>
        </div>
        <div class="result-block"><h3>The life I want to test</h3><p id="r5"></p></div>
        <div class="result-block closing-block"><h3>My next test</h3><p id="r6"></p></div>

        <div class="reflection-prompt">
          <span class="reflection-label">a question to take with you</span>
          <p class="reflection-text">If none of the three lives excites you, what does that say about what you really want?</p>
        </div>

        <div class="reflection-counter"></div>

        <div class="result-actions">
          <button class="btn-secondary" id="copy-btn">copy text</button>
          <button class="btn-secondary" id="download-btn">save as text</button>
          <button class="btn-secondary" id="save-journal-btn">save to journal</button>
          <button class="btn-secondary" id="restart-btn">redo ↺</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .textarea-label { font-family: var(--sans); font-size: 0.82rem; color: var(--ink-muted); display: block; margin-top: 1.2rem; margin-bottom: 0.4rem; }
</style>

<script>
  import { GuidedTool } from '../../scripts/guided-tool';
  import { initToolVisuals } from '../../scripts/tool-visuals';

  if (!(window as any).__guidedToolInit) {
    (window as any).__guidedToolInit = true;

  const config = {
    slug: 'tres-futuros',
    totalSteps: 6,
    fields: [
      { input: 'q1', output: 'r1' },
      { input: 'q2', output: 'r2' },
      { input: 'q3', output: 'r3' },
      { input: 'q4a', output: 'r4a' },
      { input: 'q4b', output: 'r4b' },
      { input: 'q4c', output: 'r4c' },
      { input: 'q5', output: 'r5' },
      { input: 'q6', output: 'r6' },
    ],
    encouragements: [
      '',
      'The life you have now was also a choice - even if it didn\'t feel like one.',
      'Reinvention doesn\'t have to be all or nothing. But it needs to exist on paper.',
      'That life you\'ve been hiding? It has something important to say.',
      'Feeling what excites and what weighs is more honest than listing pros and cons.',
      'Testing is braver than deciding. And gentler too.',
      'The smallest possible test is what separates dream from possibility.',
    ],
    closingReflection: 'If none of the three lives excites you, what does that say about what you really want?',
    resultTitle: '3 Plausible Futures',
    visualConfig: {
      type: 'three-paths',
      sections: [
        { id: 'vida-atual', label: 'life 1', stepRange: [1], wordClass: 'neutral' },
        { id: 'reinvencao', label: 'life 2', stepRange: [2], wordClass: 'genuine' },
        { id: 'sem-medo', label: 'life 3', stepRange: [3], wordClass: 'strategy' },
        { id: 'comparacao', label: 'excites / weighs', stepRange: [4], wordClass: 'neutral' },
        { id: 'teste', label: 'test', stepRange: [5], wordClass: 'genuine' },
        { id: 'proximo-passo', label: 'next test', stepRange: [6], wordClass: 'genuine' },
      ],
    },
  };

  const tool = new GuidedTool(config);
  tool.init();
  GuidedTool.wireExport(config);
  initToolVisuals(config.slug);

  }
</script>
