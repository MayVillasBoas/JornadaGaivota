---
import Base from '../../layouts/Base.astro';
import '../../styles/guided-tool.css';
---

<Base title="What I Really Want to Say - May">

  <section class="tool-hero">
    <span class="tool-label">tool 06</span>
    <h1>What I Really Want to Say</h1>
    <p class="tool-intro">
      Translate judgment, anger, and confusion into something clear and honest.
      For those conversations you've been putting off - because you don't know how to say it without attacking or shutting down.
    </p>
    <p class="tool-origin">Based on Nonviolent Communication - Marshall Rosenberg</p>
  </section>

  <div class="divider"></div>

  <section class="guided-experience" id="experience">

    <!-- Resume prompt -->
    <div class="resume-prompt">
      <p></p>
      <div class="resume-actions">
        <button class="btn-primary btn-resume">continue</button>
        <button class="btn-secondary btn-restart">start over</button>
      </div>
    </div>

    <!-- Unified fractal visualization -->
    <div class="fractal-viz" id="fractal-viz"></div>

    <!-- Transition screen -->
    <div class="transition-screen">
      <div class="transition-dots"><span>.</span><span>.</span><span>.</span></div>
    </div>

    <!-- Completion breath -->
    <div class="completion-breath">
      <div class="breath-text"></div>
    </div>

    <!-- Step 0: Intro -->
    <div class="step active" data-step="0">
      <div class="step-content">
        <p class="step-context">
          Nonviolent Communication starts from a simple idea: behind every judgment
          there is a feeling, and behind every feeling there is a need.
          When you discover the need, the conversation changes completely.
        </p>
        <p class="step-context">
          Here you'll translate what you're feeling into something you can actually say.
        </p>
        <button class="btn-primary step-next">begin <span class="arrow">→</span></button>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" data-step="1">
      <div class="step-header">
        <span class="step-number">1 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What happened?</h2>
        <p class="step-guide">
          Describe the concrete situation - without judgment, without interpretation.
          What did the person do or say? Facts, not labels.
          Instead of "she was rude," try "she said X while I was talking."
        </p>
        <textarea id="q1" placeholder="What happened was..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step" data-step="2">
      <div class="step-header">
        <span class="step-number">2 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What are you feeling?</h2>
        <p class="step-guide">
          Not what you think about the person - what you feel in your body.
          Anger? Sadness? Frustration? Fear? Loneliness? Confusion?
          Feelings are signals, not problems.
        </p>
        <textarea id="q2" placeholder="I'm feeling..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step" data-step="3">
      <div class="step-header">
        <span class="step-number">3 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What need isn't being met?</h2>
        <p class="step-guide">
          Every feeling points to a need. If you're angry, maybe you need
          respect. If you're sad, maybe you need connection. If you're frustrated, maybe you
          need autonomy. What's missing?
        </p>
        <div class="needs-examples">
          <span>respect</span><span>connection</span><span>autonomy</span><span>safety</span>
          <span>honesty</span><span>recognition</span><span>space</span><span>belonging</span>
          <span>trust</span><span>empathy</span><span>freedom</span><span>consideration</span>
        </div>
        <textarea id="q3" placeholder="What I need is..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="step" data-step="4">
      <div class="step-header">
        <span class="step-number">4 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What would you like to ask for?</h2>
        <p class="step-guide">
          Not a demand - a concrete, doable request. Instead of "I want you to change,"
          try "I'd like that when X happens, you could Y." A specific request,
          not an impossible transformation.
        </p>
        <textarea id="q4" placeholder="What I'd like to ask for is..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="step" data-step="5">
      <div class="step-header">
        <span class="step-number">5 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>Putting it all together</h2>
        <p class="step-guide">
          Now try to build the full sentence, in the format:
          "When [fact], I feel [feeling], because I need [need].
          I'd like [request]." You can adapt with your own words - what matters is that it's honest and non-attacking.
        </p>
        <textarea id="q5" placeholder="What I really want to say is..." rows="6"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 6 -->
    <div class="step" data-step="6">
      <div class="step-header">
        <span class="step-number">6 de 6</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>When and how will you say it?</h2>
        <p class="step-guide">
          Having clarity on what to say is half the battle. The other half is choosing the moment.
          When do you want to have this conversation? In what context? In person, in writing?
          With what energy? Plan the how.
        </p>
        <textarea id="q6" placeholder="I'll have this conversation..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary" id="finish-btn">see what I want to say <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="step" data-step="result">
      <div class="step-content result-content">
        <h2>What you really want to say</h2>
        <p class="result-intro">From raw reaction to honest speech - without attacking, without shutting down.</p>

        <div class="result-block"><h3>What happened</h3><p id="r1"></p></div>
        <div class="result-block"><h3>What I feel</h3><p id="r2"></p></div>
        <div class="result-block"><h3>What I need</h3><p id="r3"></p></div>
        <div class="result-block"><h3>My request</h3><p id="r4"></p></div>
        <div class="result-block closing-block"><h3>What I really want to say</h3><p id="r5"></p></div>
        <div class="result-block"><h3>When and how</h3><p id="r6"></p></div>

        <div class="reflection-prompt">
          <span class="reflection-label">a question to take with you</span>
          <p class="reflection-text">What changes when you swap "you always do this" for "I need..."?</p>
        </div>

        <div class="reflection-counter"></div>

        <div class="result-actions">
          <button class="btn-secondary" id="copy-btn">copy text</button>
          <button class="btn-secondary" id="download-btn">save as text</button>
          <button class="btn-secondary" id="save-journal-btn">save to journal</button>
          <button class="btn-secondary" id="restart-btn">redo ↺</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .needs-examples { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
  .needs-examples span { font-family: var(--sans); font-size: 0.78rem; color: var(--ink-muted); background: var(--warm-white); padding: 0.3rem 0.7rem; border-radius: 20px; border: 1px solid var(--border); }
</style>

<script>
  import { GuidedTool } from '../../scripts/guided-tool';
  import { initToolVisuals } from '../../scripts/tool-visuals';

  if (!(window as any).__guidedToolInit) {
    (window as any).__guidedToolInit = true;

  const config = {
    slug: 'o-que-quero-dizer',
    totalSteps: 6,
    fields: [
      { input: 'q1', output: 'r1' },
      { input: 'q2', output: 'r2' },
      { input: 'q3', output: 'r3' },
      { input: 'q4', output: 'r4' },
      { input: 'q5', output: 'r5' },
      { input: 'q6', output: 'r6' },
    ],
    encouragements: [
      '',
      'Separating fact from judgment already changes everything.',
      'Naming the feeling is the first step to not exploding.',
      'Finding the need is where the magic of NVC happens.',
      'A concrete request has a much better chance of being heard.',
      'You just translated anger into clarity. That\'s rare.',
      'Choosing the right moment is as important as the right words.',
    ],
    closingReflection: 'What changes when you swap "you always do this" for "I need..."?',
    resultTitle: 'What I Really Want to Say',
    visualConfig: {
      type: 'onion-layers',
      sections: [
        { id: 'fato', label: 'the fact', stepRange: [1], wordClass: 'neutral' },
        { id: 'sentimento', label: 'feeling', stepRange: [2], wordClass: 'fear' },
        { id: 'necessidade', label: 'need', stepRange: [3], wordClass: 'genuine' },
        { id: 'pedido', label: 'request', stepRange: [4], wordClass: 'strategy' },
        { id: 'frase-completa', label: 'full sentence', stepRange: [5], wordClass: 'genuine' },
        { id: 'momento', label: 'when and how', stepRange: [6], wordClass: 'genuine' },
      ],
    },
  };

  const tool = new GuidedTool(config);
  tool.init();
  GuidedTool.wireExport(config);
  initToolVisuals(config.slug);

  }
</script>
