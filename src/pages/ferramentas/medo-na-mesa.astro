---
import Base from '../../layouts/Base.astro';
import '../../styles/guided-tool.css';
---

<Base title="Fear Setting - May">

  <section class="tool-hero">
    <span class="tool-label">tool 01</span>
    <h1>Fear Setting</h1>
    <p class="tool-intro">
      You're avoiding something. Maybe a decision, a conversation, a change.
      This tool helps you name the fear, measure its real size,
      and discover what happens if you don't act.
    </p>
    <p class="tool-origin">Based on Fear Setting - Tim Ferriss</p>
  </section>

  <div class="divider"></div>

  <section class="guided-experience" id="experience">

    <!-- Resume prompt -->
    <div class="resume-prompt">
      <p></p>
      <div class="resume-actions">
        <button class="btn-primary btn-resume">continue</button>
        <button class="btn-secondary btn-restart">start over</button>
      </div>
    </div>

    <!-- Unified fractal visualization -->
    <div class="fractal-viz" id="fractal-viz"></div>

    <!-- Transition screen -->
    <div class="transition-screen">
      <div class="transition-dots"><span>.</span><span>.</span><span>.</span></div>
    </div>

    <!-- Completion breath -->
    <div class="completion-breath">
      <div class="breath-text"></div>
    </div>

    <!-- Step 0: Context -->
    <div class="step active" data-step="0">
      <div class="step-content">
        <p class="step-context">
          Most hard decisions don't stall from lack of information.
          They stall from fear - fear that's often bigger in your head
          than it would be in reality.
        </p>
        <p class="step-context">
          Tim Ferriss created Fear Setting as a way to look fear
          in the face: name exactly what you're afraid of, think about what you'd do
          if it happened, and calculate the real cost of not acting.
        </p>
        <p class="step-context">
          This version guides you through each step. You don't need the right answers.
          You just need to be honest.
        </p>
        <button class="btn-primary step-next">begin <span class="arrow">→</span></button>
      </div>
    </div>

    <!-- Step 1 -->
    <div class="step" data-step="1">
      <div class="step-header">
        <span class="step-number">1 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What are you avoiding?</h2>
        <p class="step-guide">
          It could be a decision, a conversation, a change. Something you know you need
          to face, but keep putting off. Write without filtering.
        </p>
        <textarea id="q1" placeholder="What I'm avoiding is..." rows="4"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step" data-step="2">
      <div class="step-header">
        <span class="step-number">2 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What exactly do you fear will happen?</h2>
        <p class="step-guide">
          Name the worst-case scenarios. Be specific.
          "It could go wrong" is too vague. What <em>exactly</em> would go wrong?
        </p>
        <textarea id="q2" placeholder="If I did this, the worst that could happen is..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step" data-step="3">
      <div class="step-header">
        <span class="step-number">3 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>How could you prevent it?</h2>
        <p class="step-guide">
          Look at each scenario you wrote above. What actions would reduce
          the chances of it happening? Fear often grows huge because we
          don't stop to think about prevention.
        </p>
        <textarea id="q3" placeholder="To reduce the chances of each scenario, I could..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="step" data-step="4">
      <div class="step-header">
        <span class="step-number">4 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>If it happened, how would you repair it?</h2>
        <p class="step-guide">
          Even in the worst case - what would you do to rebuild?
          Who could help? What resources would you have? Most
          things we fear are repairable. Almost nothing is truly irreversible.
        </p>
        <textarea id="q4" placeholder="If the worst happened, I could..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 5 -->
    <div class="step" data-step="5">
      <div class="step-header">
        <span class="step-number">5 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What is the real cost of acting?</h2>
        <p class="step-guide">
          Time, money, emotional discomfort, social risk. Be concrete.
          How much would it really cost to try? Sometimes the cost is much smaller
          than fear makes it seem.
        </p>
        <textarea id="q5" placeholder="If I act, the real cost would be..." rows="4"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 6 -->
    <div class="step" data-step="6">
      <div class="step-header">
        <span class="step-number">6 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What is the cost of not acting for 6 months?</h2>
        <p class="step-guide">
          This is the step that changes everything. We obsessively calculate
          the risk of acting - but almost never measure the price of staying still.
          What happens to your life, energy, health, and growth
          if nothing changes in the next 6 months?
        </p>
        <textarea id="q6" placeholder="If I do nothing for 6 more months, the cost will be..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary step-next">next <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Step 7 -->
    <div class="step" data-step="7">
      <div class="step-header">
        <span class="step-number">7 de 7</span>
      </div>
      <div class="step-content">
        <div class="ai-insight">
          <span class="ai-insight-marker">✦ reflection</span>
          <p class="ai-insight-text"></p>
        </div>
        <div class="step-encouragement"></div>
        <h2>What might be dying<br>because you're postponing this?</h2>
        <p class="step-guide">
          This question is more personal. Beyond the practical - what part of you,
          what possibility, what version of your life is shrinking
          while you wait?
        </p>
        <textarea id="q7" placeholder="What's dying because I'm postponing is..." rows="5"></textarea>
        <div class="step-nav">
          <button class="btn-secondary step-prev"><span class="arrow">←</span> back</button>
          <button class="btn-primary" id="finish-btn">see my map <span class="arrow">→</span></button>
        </div>
      </div>
    </div>

    <!-- Result -->
    <div class="step" data-step="result">
      <div class="step-content result-content">
        <h2>Your fear map</h2>
        <p class="result-intro">Here's what became clear. Reread slowly.</p>

        <div class="result-block"><h3>What I'm avoiding</h3><p id="r1"></p></div>
        <div class="result-block"><h3>What I fear will happen</h3><p id="r2"></p></div>
        <div class="result-block"><h3>How to prevent</h3><p id="r3"></p></div>
        <div class="result-block"><h3>How to repair</h3><p id="r4"></p></div>

        <div class="result-columns">
          <div class="result-block">
            <h3>Cost of acting</h3>
            <p id="r5"></p>
          </div>
          <div class="result-block highlight">
            <h3>Cost of not acting</h3>
            <p id="r6"></p>
          </div>
        </div>

        <div class="result-block closing-block">
          <h3>What's dying because I'm postponing</h3>
          <p id="r7"></p>
        </div>

        <div class="reflection-prompt">
          <span class="reflection-label">a question to take with you</span>
          <p class="reflection-text">Which fear did you discover is smaller than it seemed - and what decision does that unlock?</p>
        </div>

        <div class="reflection-counter"></div>

        <div class="result-actions">
          <button class="btn-secondary" id="copy-btn">copy text</button>
          <button class="btn-secondary" id="download-btn">save as text</button>
          <button class="btn-secondary" id="save-journal-btn">save to journal</button>
          <button class="btn-secondary" id="restart-btn">redo ↺</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .result-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .result-block.highlight {
    background: var(--warm-white);
    padding: 1.5rem;
    border-radius: 6px;
    border-bottom: none;
  }
  @media (max-width: 768px) {
    .result-columns { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { GuidedTool } from '../../scripts/guided-tool';
  import { initToolVisuals } from '../../scripts/tool-visuals';

  if (!(window as any).__guidedToolInit) {
    (window as any).__guidedToolInit = true;

  const config = {
    slug: 'medo-na-mesa',
    totalSteps: 7,
    fields: [
      { input: 'q1', output: 'r1' },
      { input: 'q2', output: 'r2' },
      { input: 'q3', output: 'r3' },
      { input: 'q4', output: 'r4' },
      { input: 'q5', output: 'r5' },
      { input: 'q6', output: 'r6' },
      { input: 'q7', output: 'r7' },
    ],
    encouragements: [
      '',
      'Naming what you avoid is already an act of courage.',
      'The more specific the fear, the smaller it gets.',
      'Most fears have prevention. That changes everything.',
      'Almost nothing is irreversible. You have more resources than you think.',
      'The cost of acting is usually smaller than fear makes it seem.',
      'This is the step few people take - measuring the cost of not acting.',
      'This question goes beyond the practical. Listen to what comes.',
    ],
    closingReflection: 'Which fear did you discover is smaller than it seemed - and what decision does that unlock?',
    resultTitle: 'Fear Setting',
    visualConfig: {
      type: 'fear-map',
      sections: [
        { id: 'evitando', label: 'avoiding', stepRange: [1], wordClass: 'fear' },
        { id: 'medos', label: 'fears', stepRange: [2], wordClass: 'fear' },
        { id: 'prevencao', label: 'prevention', stepRange: [3], wordClass: 'strategy' },
        { id: 'reparacao', label: 'repair', stepRange: [4], wordClass: 'strategy' },
        { id: 'custo-agir', label: 'cost of acting', stepRange: [5], wordClass: 'neutral' },
        { id: 'custo-inacao', label: 'cost of not acting', stepRange: [6], wordClass: 'obligation' },
        { id: 'veredicto', label: 'verdict', stepRange: [7], wordClass: 'genuine' },
      ],
    },
  };

  const tool = new GuidedTool(config);
  tool.init();
  GuidedTool.wireExport(config);
  initToolVisuals(config.slug);

  }
</script>
