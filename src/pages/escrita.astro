<style>
  .page-header {
    max-width: 680px;
    margin: 5rem auto 4rem;
    padding: 0 2rem;
  }

  .page-header h1 { font-size: 2.4rem; margin-bottom: 1rem; }

  .page-sub {
    font-size: 1rem !important;
    line-height: 1.7 !important;
    max-width: 500px;
  }

  .epigraph {
    max-width: 680px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }

  .epigraph blockquote {
    border-left: 2px solid var(--border);
    padding-left: 1.5rem;
    margin: 0;
  }

  .epigraph blockquote p {
    font-family: var(--serif);
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--ink-light);
    margin-bottom: 1rem;
  }

  .epigraph blockquote p:last-of-type {
    margin-bottom: 1rem;
  }

  .epigraph cite {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--ink-muted);
    font-style: normal;
    letter-spacing: 0.02em;
  }

  .posts-section {
    padding: 0 2rem;
    margin-bottom: 4rem;
  }

  .section-label {
    margin-bottom: 1.5rem;
  }

  .section-label h2 {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.4rem;
  }

  .section-sub {
    font-size: 0.88rem !important;
    font-style: italic;
    color: var(--ink-muted) !important;
  }

  .posts-list {
    margin-bottom: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--border);
  }

  .post-item a {
    display: block;
    padding: 2rem 0;
    transition: all 0.3s;
  }

  .post-item a:hover h2 { color: var(--accent); }

  .post-item h2 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    transition: color 0.3s;
  }

  .post-item p {
    font-size: 0.92rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .date {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--ink-muted);
  }
</style>
