---
import Base from '../layouts/Base.astro';
import { books } from '../data/books';
---

<Base title="Books - May">
  <section class="page-header">
    <h1>📖 From my Kindle</h1>
    <p class="page-sub">Words that stayed with me. Highlights from books that shaped how I think.</p>
  </section>

  <section class="books-content narrow">
    {books.map((book) => (
      <article class="book-card">
        <header class="book-header">
          <h2 class="book-title">{book.title}</h2>
          <p class="book-author">{book.author}</p>
          {book.subtitle && <p class="book-subtitle">{book.subtitle}</p>}
        </header>

        <div class="book-highlights">
          {book.highlights.map((quote) => (
            <blockquote class="highlight">
              <p>{quote}</p>
            </blockquote>
          ))}
        </div>
      </article>
    ))}
  </section>
</Base>

<style>
  .page-header {
    max-width: 680px;
    margin: 5rem auto 3rem;
    padding: 0 2rem;
  }

  .page-header h1 {
    font-size: 2.4rem;
    margin-bottom: 0.8rem;
  }

  .page-sub {
    font-size: 0.85rem !important;
    color: var(--ink-muted) !important;
  }

  .books-content {
    padding: 0 2rem;
    margin-bottom: 6rem;
  }

  .book-card {
    margin-bottom: 3.5rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--border, rgba(26, 26, 24, 0.08));
  }

  .book-card:last-child {
    border-bottom: none;
  }

  .book-header {
    margin-bottom: 1.5rem;
  }

  .book-title {
    font-family: 'EB Garamond', serif;
    font-size: 1.4rem;
    font-weight: 500;
    margin-bottom: 0.3rem;
    color: var(--ink, #1a1a18);
  }

  .book-author {
    font-family: var(--sans, Inter, sans-serif);
    font-size: 0.85rem;
    color: var(--ink-muted, #6b6b68);
    margin-bottom: 0.2rem;
  }

  .book-subtitle {
    font-family: var(--sans, Inter, sans-serif);
    font-size: 0.8rem;
    color: var(--ink-muted, #6b6b68);
    font-style: italic;
    opacity: 0.7;
  }

  .book-highlights {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .highlight {
    margin: 0;
    padding: 1.2rem 1.5rem;
    background: rgba(26, 26, 24, 0.02);
    border-left: 2px solid rgba(26, 26, 24, 0.12);
    border-radius: 0 4px 4px 0;
    transition: border-color 0.3s, background 0.3s;
  }

  .highlight:hover {
    border-left-color: var(--accent, #1a1a18);
    background: rgba(26, 26, 24, 0.04);
  }

  .highlight p {
    font-family: 'EB Garamond', serif;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ink, #1a1a18);
    margin: 0;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .page-header {
      margin-top: 3rem;
    }

    .book-title {
      font-size: 1.2rem;
    }

    .highlight {
      padding: 1rem 1.2rem;
    }

    .highlight p {
      font-size: 0.95rem;
    }
  }
</style>
