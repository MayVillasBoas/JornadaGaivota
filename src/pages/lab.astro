---
import Base from '../layouts/Base.astro';
---

<Base title="Labs — May.labs">

  <div class="lab-landing">

    <div class="lab-hero">
      <h1>Labs</h1>
      <p class="lab-subtitle">
        In 2014, I learned to code computer graphics from scratch — C++ and OpenGL, rendering triangular meshes, writing optimization algorithms to make them run. I fell in love with the intersection of math, modeling, and visual computation.
      </p>
      <p class="lab-subtitle faded">
        It took over ten years to come back. These are the explorations I'm building now.
      </p>
    </div>

    <div class="lab-cards">

      <a href="/fractais" class="lab-card">
        <span class="card-number">01</span>
        <h2>Fractals in Nature</h2>
        <p>A simple rule, repeated — and the universe builds itself. Ferns, romanesco, lightning, snowflakes, and nautilus shells rendered as interactive visualizations.</p>
        <span class="card-arrow">&rarr;</span>
      </a>

      <a href="/complexity" class="lab-card">
        <span class="card-number">02</span>
        <h2>Notes on Complexity</h2>
        <p>Emergence, self-organization, the edge of chaos, and permeable boundaries — the science of how simple parts create complex wholes. Inspired by Neil Theise.</p>
        <span class="card-arrow">&rarr;</span>
      </a>

      <a href="/patterns" class="lab-card">
        <span class="card-number">03</span>
        <h2>Patterns</h2>
        <p>Flow fields, mycelium networks, phyllotaxis, auroras, clouds, and sun rays — generative visualizations of natural phenomena driven by noise and particles.</p>
        <span class="card-arrow">&rarr;</span>
      </a>

    </div>

  </div>

</Base>

<style is:global>
  body:has(.lab-landing) {
    background: #1a1a1a;
  }

  body:has(.lab-landing) .site-header {
    background: #1a1a1a;
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  body:has(.lab-landing) .logo {
    color: rgba(255, 255, 255, 0.85);
  }

  body:has(.lab-landing) .nav-links a {
    color: rgba(255, 255, 255, 0.4);
  }

  body:has(.lab-landing) .nav-links a:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  body:has(.lab-landing) .lang-toggle {
    color: rgba(255, 255, 255, 0.4) !important;
    border-color: rgba(255, 255, 255, 0.15);
  }

  body:has(.lab-landing) .mobile-menu-btn span {
    background: rgba(255, 255, 255, 0.7);
  }

  body:has(.lab-landing) footer {
    display: none;
  }
</style>

<style>
  .lab-landing {
    min-height: calc(100vh - 60px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    gap: 4rem;
  }

  .lab-hero {
    text-align: center;
    max-width: 560px;
  }

  .lab-hero h1 {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 3.5rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2rem;
    letter-spacing: 0.02em;
  }

  .lab-subtitle {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1rem;
  }

  .lab-subtitle.faded {
    color: rgba(255, 255, 255, 0.25);
    font-style: italic;
  }

  .lab-cards {
    display: flex;
    gap: 1.5rem;
    max-width: 900px;
    width: 100%;
  }

  .lab-card {
    flex: 1;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.4s ease;
    position: relative;
    background: rgba(255, 255, 255, 0.02);
  }

  .lab-card:hover {
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  .card-number {
    font-family: var(--sans, 'Inter', sans-serif);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.2);
    display: block;
    margin-bottom: 1rem;
  }

  .lab-card h2 {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 1.4rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.8rem;
    letter-spacing: 0.02em;
  }

  .lab-card p {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1.5rem;
  }

  .card-arrow {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.15);
    transition: all 0.3s ease;
  }

  .lab-card:hover .card-arrow {
    color: rgba(255, 255, 255, 0.5);
    transform: translateX(4px);
    display: inline-block;
  }

  @media (max-width: 768px) {
    .lab-cards {
      flex-direction: column;
    }

    .lab-hero h1 {
      font-size: 2.5rem;
    }

    .lab-landing {
      padding: 2rem 1.5rem;
      gap: 3rem;
    }
  }
</style>
