---
import Base from '../layouts/Base.astro';
---

<Base title="Lab — Unfold">

  <div class="lab-container">

    <!-- Intro -->
    <section class="lab-intro">
      <div class="intro-content">
        <h1>Lab</h1>
        <p class="intro-text">
          The most beautiful patterns aren't designed — they're <em>cultivated</em>.
        </p>
        <p class="intro-text faded">
          Nature gives a simple rule, repeats it, and lets complexity emerge.
        </p>
        <div class="scroll-hint">
          <span>↓</span>
        </div>
      </div>
    </section>

    <section class="lab-section" data-viz="flow-field">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Flow Field</h2>
        <p>3,000 particles following invisible currents generated by Simplex Noise — the coherent noise invented by Ken Perlin to give organic texture to everything that looks natural in computer graphics. Each particle samples a vector field and follows the local angle. The result resembles wind, water, or the flow of thoughts.</p>
        <span class="lab-interact">move the mouse to disturb the field</span>
      </div>
    </section>

    <section class="lab-section" data-viz="mycelium">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Mycelium Network</h2>
        <p>Stochastic branching with noise perturbation — the same logic that mycelium networks and neurons use to grow. Each tip advances at an angle slightly deviated by noise, with a decreasing probability of forking. The result is an organic network that never repeats.</p>
        <span class="lab-interact">click to plant new seeds</span>
      </div>
    </section>

    <section class="lab-section" data-viz="phyllotaxis">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Phyllotaxis Bloom</h2>
        <p>The golden angle — 137.508° — is the angle nature uses to distribute seeds, petals, and leaves without overlap. Each point is placed at this angle from the previous one, at a distance proportional to the square root of n. It's the algorithm of the sunflower, the pineapple, the pinecone.</p>
        <span class="lab-interact">hover the mouse to illuminate points</span>
      </div>
    </section>

    <section class="lab-section" data-viz="romanesco">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Romanesco</h2>
        <p>Romanesco broccoli is nature's most beautiful fractal — each bud is a miniature copy of the whole, arranged at the golden angle (137.508°). The same rule repeats at every scale: spirals within spirals within spirals. It's pure self-similarity — the signature of fractals.</p>
        <span class="lab-interact">click to regenerate</span>
      </div>
    </section>

    <section class="lab-section" data-viz="aurora">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Particle Aurora</h2>
        <p>Curtains of light inspired by the aurora borealis — particles arranged in horizontal bands rippled by 2D noise, with vertical gradients and additive blending. When light overlaps, it adds up. Each layer uses a different color from the palette, creating atmospheric depth.</p>
        <span class="lab-interact">move the mouse to tilt the curtains</span>
      </div>
    </section>

    <section class="lab-section" data-viz="clouds">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Cloud Fractal</h2>
        <p>Volumetric clouds built with 4 octaves of 3D Simplex Noise — each layer with different frequency and speed. The first octave creates the large shapes (cumulus), the last adds fine details (wisps). The time dimension makes everything evolve continuously.</p>
        <span class="lab-interact">move the mouse to illuminate</span>
      </div>
    </section>

    <section class="lab-section" data-viz="sunrays">
      <canvas></canvas>
      <div class="lab-info">
        <h2>Sun Rays</h2>
        <p>Crepuscular rays (god rays) — radial light beams modulated by 3D noise that simulates shadows from invisible clouds. Each ray is a triangle with a radial gradient, and dust particles float in the light like suspended pollen. The principle: light travels in a straight line, but clouds create gaps.</p>
        <span class="lab-interact">move the mouse to guide the sun</span>
      </div>
    </section>
  </div>

  <!-- Side dot navigation -->
  <nav class="lab-dots" aria-label="Sections">
    <button class="dot active" data-section="0" aria-label="Flow Field"></button>
    <button class="dot" data-section="1" aria-label="Mycelium"></button>
    <button class="dot" data-section="2" aria-label="Phyllotaxis"></button>
    <button class="dot" data-section="3" aria-label="Romanesco"></button>
    <button class="dot" data-section="4" aria-label="Aurora"></button>
    <button class="dot" data-section="5" aria-label="Clouds"></button>
    <button class="dot" data-section="6" aria-label="Sun Rays"></button>
  </nav>

</Base>

<script>
  import { FlowField } from '../scripts/lab/flow-field';
  import { MyceliumNetwork } from '../scripts/lab/mycelium-network';
  import { PhyllotaxisBloom } from '../scripts/lab/phyllotaxis-bloom';
  import { Romanesco } from '../scripts/lab/romanesco';
  import { ParticleAurora } from '../scripts/lab/particle-aurora';
  import { CloudFractal } from '../scripts/lab/cloud-fractal';
  import { SunRays } from '../scripts/lab/sun-rays';
  import type { BaseVisualization } from '../scripts/lab/base-visualization';

  const sections = document.querySelectorAll('.lab-section');
  const dots = document.querySelectorAll('.lab-dots .dot');
  const vizMap = new Map<Element, BaseVisualization>();
  let activeViz: BaseVisualization | null = null;

  const constructors: Record<string, new (canvas: HTMLCanvasElement) => BaseVisualization> = {
    'flow-field': FlowField,
    'mycelium': MyceliumNetwork,
    'phyllotaxis': PhyllotaxisBloom,
    'romanesco': Romanesco,
    'aurora': ParticleAurora,
    'clouds': CloudFractal,
    'sunrays': SunRays,
  };

  // IntersectionObserver on the scroll container
  const container = document.querySelector('.lab-container');

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      const section = entry.target;
      const idx = Array.from(sections).indexOf(section);

      if (entry.isIntersecting && entry.intersectionRatio > 0.3) {
        let viz = vizMap.get(section);
        if (!viz) {
          const canvas = section.querySelector('canvas')!;
          const type = section.getAttribute('data-viz')!;
          const Ctor = constructors[type];
          if (Ctor) {
            viz = new Ctor(canvas);
            vizMap.set(section, viz);
          }
        }
        if (viz && viz !== activeViz) {
          activeViz?.stop();
          viz.start();
          activeViz = viz;
        }
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      }
    }
  }, { threshold: 0.3, root: container });

  sections.forEach(s => observer.observe(s));

  // Dot navigation
  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const idx = parseInt(dot.getAttribute('data-section') || '0');
      sections[idx]?.scrollIntoView({ behavior: 'smooth' });
    });
  });
</script>

<style is:global>
  /* Dark theme override for lab page */
  body:has(.lab-container) {
    background: #1a1a1a;
  }

  body:has(.lab-container) .site-header {
    background: #1a1a1a;
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  body:has(.lab-container) .logo {
    color: rgba(255, 255, 255, 0.85);
  }

  body:has(.lab-container) .nav-links a {
    color: rgba(255, 255, 255, 0.4);
  }

  body:has(.lab-container) .nav-links a:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  body:has(.lab-container) .lang-toggle {
    color: rgba(255, 255, 255, 0.4) !important;
    border-color: rgba(255, 255, 255, 0.15);
  }

  body:has(.lab-container) .mobile-menu-btn span {
    background: rgba(255, 255, 255, 0.7);
  }

  body:has(.lab-container) footer {
    display: none;
  }
</style>

<style>
  .lab-container {
    scroll-snap-type: y proximity;
    overflow-y: auto;
    height: calc(100vh - 60px);
  }

  .lab-section {
    position: relative;
    width: 100%;
    height: calc(100vh - 60px);
    overflow: hidden;
    scroll-snap-align: start;
  }

  .lab-section canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .lab-info {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    max-width: 380px;
    pointer-events: none;
  }

  .lab-info h2 {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 1.3rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.6rem;
    letter-spacing: 0.02em;
  }

  .lab-info p {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.25);
    margin-bottom: 0.5rem;
  }

  .lab-interact {
    font-family: var(--sans, 'Inter', sans-serif);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.2);
    font-style: italic;
  }

  .lab-dots {
    position: fixed;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .lab-dots .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .lab-dots .dot:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .lab-dots .dot.active {
    background: rgba(255, 255, 255, 0.7);
    transform: scale(1.4);
  }

  /* Intro section */
  .lab-intro {
    height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    scroll-snap-align: start;
    position: relative;
  }

  .intro-content {
    max-width: 560px;
    padding: 2rem;
    text-align: center;
  }

  .intro-content h1 {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 3.5rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 2.5rem;
    letter-spacing: 0.02em;
  }

  .intro-text {
    font-family: var(--serif, 'EB Garamond', serif);
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 1.5rem;
  }

  .intro-text em {
    color: rgba(255, 255, 255, 0.75);
    font-style: italic;
  }

  .intro-text.faded {
    color: rgba(255, 255, 255, 0.35);
    font-style: italic;
  }

  .scroll-hint {
    margin-top: 3rem;
    color: rgba(255, 255, 255, 0.15);
    font-size: 1.2rem;
    animation: hint-bounce 2.5s ease-in-out infinite;
  }

  @keyframes hint-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.3; }
    50% { transform: translateY(6px); opacity: 0.6; }
  }

  @media (max-width: 768px) {
    .lab-container {
      scroll-snap-type: none;
    }

    .lab-dots {
      right: 0.8rem;
      gap: 8px;
    }

    .lab-dots .dot {
      width: 6px;
      height: 6px;
    }

    .lab-info {
      bottom: 1.5rem;
      left: 1.5rem;
      max-width: 280px;
    }

    .lab-info h2 {
      font-size: 1.1rem;
    }

    .lab-info p {
      font-size: 0.78rem;
    }

    .intro-content h1 {
      font-size: 2.5rem;
    }
  }
</style>
