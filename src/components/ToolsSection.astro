---
const toolCategories = [
  {
    name: 'Decide',
    tools: [
      { slug: 'medo-na-mesa', name: 'Fear Setting', framework: 'Fear Setting', mentor: 'Tim Ferriss', steps: 7 },
      { slug: 'tres-futuros', name: '3 Plausible Futures', framework: 'Odyssey Plan', mentor: 'Bill Burnett & Dave Evans', steps: 5 },
      { slug: 'sim-inteiro', name: 'Hell Yes or No', framework: 'Hell Yes or No', mentor: 'Derek Sivers', steps: 5 },
    ]
  },
  {
    name: 'Listen In',
    tools: [
      { slug: 'bussola-interna', name: 'Inner Compass', framework: 'North Star', mentor: 'Martha Beck', steps: 5 },
      { slug: 'auditoria-de-energia', name: 'Energy Audit', framework: 'Energy Audit', mentor: 'May', steps: 5 },
    ]
  },
  {
    name: 'Communicate',
    tools: [
      { slug: 'o-que-quero-dizer', name: 'What I Really Want to Say', framework: 'NVC', mentor: 'Marshall Rosenberg', steps: 5 },
      { slug: 'prototipos-de-futuro', name: 'Future Prototypes', framework: 'Life Prototyping', mentor: 'Bill Burnett & Dave Evans', steps: 5 },
    ]
  }
];
---

<section class="section" id="ferramentas">
  <h2 class="section-title">Tools</h2>

  {toolCategories.map(category => (
    <div class="tools-category">
      <h3 class="tools-category-name">{category.name}</h3>
      <div class="tools-grid">
        {category.tools.map(tool => (
          <a href={`/ferramentas/${tool.slug}`} class="tool-card">
            <span class="tool-steps">{tool.steps} steps</span>
            <h3>{tool.name}</h3>
            <span class="tool-meta">{tool.framework}</span>
            <span class="tool-meta tool-mentor">{tool.mentor}</span>
          </a>
        ))}
      </div>
    </div>
  ))}

  <div class="tools-category">
    <div class="tools-grid">
      <div class="tool-card placeholder">
        <span class="badge-coming">coming soon</span>
        <h3>Life Calendar</h3>
        <span class="tool-meta">Tim Urban · Wait But Why</span>
      </div>
    </div>
  </div>
</section>
