---
import type { LabViz } from '../../data/lab-registry';

interface Props {
  viz: LabViz;
}

const { viz } = Astro.props;
---

<div class="lab-preview-card" data-viz-slug={viz.slug} data-viz-category={viz.category}>
  <div class="card-visual">
    <img src={viz.thumbnail} alt={viz.name} loading="lazy" width="400" height="300" />
    <canvas class="hover-canvas" width="400" height="300"></canvas>
  </div>
  <div class="card-meta">
    <h4>{viz.name}</h4>
    <p>{viz.description}</p>
  </div>
</div>

<style>
  .lab-preview-card {
    min-width: 280px;
    width: 280px;
    flex-shrink: 0;
    scroll-snap-align: start;
    cursor: pointer;
    transition: transform 0.3s ease-in-out;
  }

  .lab-preview-card:hover {
    transform: translateY(-3px);
  }

  .card-visual {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 4 / 3;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: border-color 0.3s;
  }

  .lab-preview-card:hover .card-visual {
    border-color: rgba(255, 255, 255, 0.2);
  }

  .card-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-visual .hover-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .card-meta {
    padding: 0.75rem 0.25rem 0;
  }

  .card-meta h4 {
    font-family: var(--serif);
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 0.2rem;
  }

  .card-meta p {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.35);
    line-height: 1.4;
  }

  @media (max-width: 768px) {
    .lab-preview-card {
      min-width: 240px;
      width: 240px;
    }
  }
</style>
