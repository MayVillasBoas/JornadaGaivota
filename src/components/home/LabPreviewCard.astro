---
import type { LabViz } from '../../data/lab-registry';

interface Props {
  viz: LabViz;
}

const { viz } = Astro.props;
---

<div class="lab-preview-card" data-viz-slug={viz.slug} data-viz-category={viz.category}>
  <div class="card-visual">
    <img src={viz.thumbnail} alt={viz.name} loading="lazy" width="800" height="600" />
    <canvas class="hover-canvas"></canvas>
  </div>
  <div class="card-meta">
    <h4>{viz.name}</h4>
    <p>{viz.description}</p>
  </div>
</div>

<style>
  .lab-preview-card {
    cursor: pointer;
    transition: transform 0.3s ease-in-out;
  }

  .lab-preview-card:hover {
    transform: translateY(-3px);
  }

  .card-visual {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 4 / 3;
    border: 1px solid var(--border);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .lab-preview-card:hover .card-visual {
    border-color: var(--border-light);
    box-shadow: var(--shadow-md);
  }

  .card-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-visual .hover-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .card-meta {
    padding: 0.75rem 0 0;
  }

  .card-meta h4 {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .card-meta p {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--ink-muted);
    line-height: 1.4;
    margin: 0;
  }
</style>
