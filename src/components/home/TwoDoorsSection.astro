---
// Two doors: building at work (coming soon) and building in life (active)
// Editorial typographic sections - no cards, pure hierarchy
---

<section class="two-doors narrow">

  <div class="door-section">
    <a href="/building-in-life" class="door-link">
      <span class="door-label">Explore</span>
      <h2>Building in life</h2>
      <p class="door-desc">
        How we navigate uncertainty in careers, relationships,
        and the decisions that shape our lives.
      </p>
      <span class="door-arrow">&rarr;</span>
    </a>

    <div class="door-items">
      <a href="/copilot" class="door-item">
        <span class="item-name">Decision Copilot</span>
        <span class="item-sub">AI-guided decision tool</span>
        <span class="item-arrow">&rarr;</span>
      </a>
      <a href="/ferramentas" class="door-item">
        <span class="item-name">Frameworks & Tools</span>
        <span class="item-arrow">&rarr;</span>
      </a>
      <a href="/escrita" class="door-item">
        <span class="item-name">Essays</span>
        <span class="item-arrow">&rarr;</span>
      </a>
      <a href="/referencias" class="door-item">
        <span class="item-name">Books & Mentors</span>
        <span class="item-arrow">&rarr;</span>
      </a>
    </div>
  </div>

  <div class="divider"></div>

  <div class="door-section door-muted">
    <a href="/building-at-work" class="door-link">
      <span class="door-label">Coming soon</span>
      <h2>Building at work</h2>
      <p class="door-desc">
        Product, AI, and navigating ambiguity in tech teams.
      </p>
      <span class="door-arrow">&rarr;</span>
    </a>
  </div>

</section>

<style>
  .two-doors {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 2rem 2rem;
  }

  .divider {
    width: 40px;
    height: 1px;
    background: var(--border);
    margin: 2.5rem auto;
  }

  .door-link {
    display: block;
    text-decoration: none;
    position: relative;
  }

  .door-label {
    display: block;
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    margin-bottom: 0.75rem;
  }

  .door-link h2 {
    font-family: var(--serif);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 0.75rem;
    transition: color 0.3s;
  }

  .door-link:hover h2 {
    color: var(--accent);
  }

  .door-desc {
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--ink-light);
    margin-bottom: 0;
  }

  .door-arrow {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--ink-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
  }

  .door-link:hover .door-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  /* Muted state for coming soon */
  .door-muted .door-link h2 {
    color: var(--ink-muted);
  }

  .door-muted .door-link:hover h2 {
    color: var(--ink-light);
  }

  .door-muted .door-desc {
    color: var(--ink-muted);
  }

  /* Sub-links for the active door */
  .door-items {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .door-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: color 0.3s;
  }

  .door-item:first-child {
    border-top: 1px solid var(--border);
  }

  .item-name {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--ink);
    transition: color 0.3s;
  }

  .item-sub {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--ink-muted);
    flex: 1;
  }

  .item-arrow {
    font-size: 1rem;
    color: var(--ink-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .door-item:hover .item-name {
    color: var(--accent);
  }

  .door-item:hover .item-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .two-doors {
      padding: 0 1.5rem 1.5rem;
    }

    .door-link h2 {
      font-size: 1.5rem;
    }

    .item-arrow,
    .door-arrow {
      display: none;
    }
  }
</style>
