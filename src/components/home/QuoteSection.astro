---
import { getAllQuotes, getRandomQuote } from '../../data/books';

const allQuotes = getAllQuotes(['relationships']);
const initial = getRandomQuote(['relationships']);
---

<section class="quote-section">
  <div class="quote-content">
    <span class="section-label">FROM BOOKS I'VE READ AND LOVED</span>
    <div class="quote-block">
      <span class="quote-mark" aria-hidden="true">&ldquo;</span>
      <blockquote class="home-quote">
        <p class="quote-text">{initial.text}</p>
      </blockquote>
      <cite class="quote-source">
        <span class="quote-author">{initial.author}</span>
        <span class="quote-sep"> — </span>
        <span class="quote-book">{initial.title}</span>
      </cite>
    </div>
    <div class="quote-footer">
      <button class="quote-next" aria-label="Next quote">another &rarr;</button>
      <a href="/books" class="quote-link">all highlights &rarr;</a>
    </div>
  </div>
  <script type="application/json" id="quotes-data" set:html={JSON.stringify(allQuotes)} />
</section>

<style>
  .quote-section {
    padding: 6rem 2rem 5rem;
  }

  .quote-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .section-label {
    display: block;
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-muted);
    margin-bottom: 2rem;
  }

  .quote-block {
    position: relative;
    margin-bottom: 2rem;
  }

  .quote-mark {
    position: absolute;
    top: -1.5rem;
    left: -0.5rem;
    font-family: var(--serif);
    font-size: 6rem;
    line-height: 1;
    color: var(--border);
    pointer-events: none;
    user-select: none;
  }

  .home-quote {
    margin: 0;
    padding-left: 0.5rem;
  }

  .quote-text {
    font-family: var(--serif);
    font-size: 2rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.7;
    color: var(--ink);
    margin-bottom: 1.5rem;
    transition: opacity 0.4s ease;
  }

  .quote-source {
    display: block;
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 300;
    font-style: normal;
    color: var(--ink-muted);
    padding-left: 0.5rem;
    transition: opacity 0.4s ease;
  }

  .quote-author {
    font-weight: 400;
    color: var(--ink-light);
  }

  .quote-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-left: 0.5rem;
  }

  .quote-next {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--ink-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: color 0.3s;
  }

  .quote-next:hover {
    color: var(--accent);
  }

  .quote-link {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--ink-muted);
    text-decoration: none;
    transition: color 0.3s;
  }

  .quote-link:hover {
    color: var(--accent);
  }

  .quote-text.fading,
  .quote-source.fading {
    opacity: 0;
  }

  @media (max-width: 768px) {
    .quote-section {
      padding: 4rem 1.5rem 3rem;
    }

    .quote-text {
      font-size: 1.5rem;
    }

    .quote-mark {
      font-size: 4rem;
      top: -1rem;
    }
  }
</style>

<script>
  try {
    const dataEl = document.getElementById('quotes-data');
    if (!dataEl) throw new Error('no data');

    const quotes = JSON.parse(dataEl.textContent || '[]');
    if (quotes.length === 0) throw new Error('empty');

    const textEl = document.querySelector('.quote-text') as HTMLElement;
    const authorEl = document.querySelector('.quote-author') as HTMLElement;
    const bookEl = document.querySelector('.quote-book') as HTMLElement;
    const sourceEl = document.querySelector('.quote-source') as HTMLElement;
    const nextBtn = document.querySelector('.quote-next');

    let currentIndex = Math.floor(Math.random() * quotes.length);

    function nextDifferentBook(): number {
      const currentTitle = quotes[currentIndex]?.title;
      let next = (currentIndex + 1) % quotes.length;
      let attempts = 0;
      while (quotes[next]?.title === currentTitle && attempts < quotes.length) {
        next = (next + 1) % quotes.length;
        attempts++;
      }
      return next;
    }

    function showQuote(index: number) {
      const quote = quotes[index];
      if (!quote) return;

      textEl?.classList.add('fading');
      sourceEl?.classList.add('fading');

      setTimeout(() => {
        if (textEl) textEl.textContent = quote.text;
        if (authorEl) authorEl.textContent = quote.author;
        if (bookEl) bookEl.textContent = quote.title;

        textEl?.classList.remove('fading');
        sourceEl?.classList.remove('fading');
      }, 400);
    }

    showQuote(currentIndex);

    nextBtn?.addEventListener('click', () => {
      currentIndex = nextDifferentBook();
      showQuote(currentIndex);
    });

    setInterval(() => {
      currentIndex = nextDifferentBook();
      showQuote(currentIndex);
    }, 30000);
  } catch {
    // SSR fallback is already rendered
  }
</script>
