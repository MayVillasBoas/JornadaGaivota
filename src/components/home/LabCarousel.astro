---
import type { LabCategory, LabViz } from '../../data/lab-registry';
import LabPreviewCard from './LabPreviewCard.astro';

interface Props {
  category: LabCategory;
  vizzes: LabViz[];
}

const { category, vizzes } = Astro.props;
---

<div class="lab-carousel">
  <div class="carousel-header">
    <h3>{category.label}</h3>
    <a href={category.page} class="see-all">Explore all {vizzes.length} &rarr;</a>
  </div>
  <div class="carousel-track">
    {vizzes.map((viz) => (
      <LabPreviewCard viz={viz} />
    ))}
  </div>
  <div class="carousel-controls">
    <button class="carousel-prev" aria-label="Previous">&larr;</button>
    <button class="carousel-next" aria-label="Next">&rarr;</button>
  </div>
</div>

<style>
  .lab-carousel {
    position: relative;
    margin-bottom: 3rem;
  }

  .lab-carousel:last-child {
    margin-bottom: 0;
  }

  .carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }

  .carousel-header h3 {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.6);
  }

  .see-all {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 300;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: color 0.3s;
  }

  .see-all:hover {
    color: rgba(255, 255, 255, 0.7);
  }

  .carousel-track {
    display: flex;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
    padding-bottom: 0.5rem;
  }

  .carousel-track::-webkit-scrollbar {
    height: 4px;
  }

  .carousel-track::-webkit-scrollbar-track {
    background: transparent;
  }

  .carousel-track::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }

  .carousel-controls {
    position: absolute;
    top: 0;
    right: 0;
    display: flex;
    gap: 0.5rem;
    transform: translateY(-100%);
    padding-bottom: 0.5rem;
  }

  .carousel-prev,
  .carousel-next {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: transparent;
    color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.3s, color 0.3s;
  }

  .carousel-prev:hover,
  .carousel-next:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: rgba(255, 255, 255, 0.8);
  }

  @media (max-width: 768px) {
    .carousel-controls {
      display: none;
    }
  }
</style>
